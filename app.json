{
  "expo": {
    "name": "AFTER PAY",
    "slug": "after-pay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "afterpay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Pakistan's #1 Buy Now, Pay Later mobile phone store. Shop the latest smartphones from Samsung, Apple, Oppo, Xiaomi, Tecno, and more — on easy installments.",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4EA97A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afterpayapp.pk",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "AFTER PAY needs access to your photo library so you can upload documents for your installment plan application.",
        "NSPhotoLibraryAddUsageDescription": "AFTER PAY needs access to save images.",
        "NSCameraUsageDescription": "AFTER PAY uses the camera to let you photograph documents for your installment application."
      }
    },
    "android": {
      "package": "com.afterpayapp.pk",
      "versionCode": 3,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "backgroundColor": "#4EA97A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "afterpay"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "AFTER PAY needs access to your photos to upload documents for your installment plan application."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "99ec9829-cf91-4845-b54e-a29f62629ee3"
      },
      "router": {
        "origin": "https://replit.com/"
      }
    },
    "owner": "afterpay786"
  }
}
